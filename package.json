{
  "name": "open-agent-team",
  "description": "Declarative multi-agent orchestration for OpenCode: Admin → Leader → Worker hierarchy, team.json config, isolated workspaces (git worktree), and the oat CLI.",
  "version": "0.1.2",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "files": [
    "dist",
    "docs",
    "schema",
    "team.example.json",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "oat": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "license": "MIT",
  "author": {
    "name": "Herbert He",
    "email": "Herbert.He0229@gmail.com"
  },
  "homepage": "https://github.com/herberthe/open-agent-team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/herberthe/open-agent-team.git"
  },
  "keywords": [
    "agent",
    "agent-orchestration",
    "agent-team",
    "ai",
    "ai-agent",
    "cli",
    "coding-agent",
    "declarative",
    "git-worktree",
    "llm",
    "multi-agent",
    "oat",
    "opencode",
    "opencode-ai",
    "orchestration",
    "orchestrator",
    "workspace",
    "open-agent-team"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.2",
    "@opencode-ai/sdk": "^1.3.2",
    "commander": "^14.0.0",
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "simple-git": "^3.28.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
